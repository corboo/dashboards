{
  "redirects": [
    {
      "source": "/youtube-dashboard.html",
      "destination": "https://inceptionpointai.github.io/youtube-dashboard/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
